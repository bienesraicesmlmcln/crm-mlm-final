:root {
  color-scheme: light;
  --bg: #f6f6f7;
  --panel: #ffffff;
  --ink: #111113;
  --muted: #686a70;
  --line: #e2e2e5;
  --accent: #bd1731;
  --accent-dark: #8f1025;
  --gold: #bd1731;
  --danger: #b42338;
  --navy: #101012;
  --soft-red: #f8e8eb;
  --green: #16805b;
  --green-soft: #e7f6ef;
  --yellow: #946300;
  --yellow-soft: #fff3c7;
  --blue: #1f64b5;
  --blue-soft: #e8f1ff;
  --shadow: 0 18px 50px rgba(16, 16, 18, 0.09);
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

[hidden] {
  display: none !important;
}

body {
  margin: 0;
  min-height: 100vh;
  background: var(--bg);
  color: var(--ink);
}

body[data-theme="light"] {
  --bg: #fafafa;
  --panel: #ffffff;
  --ink: #15171a;
  --muted: #666d76;
  --line: #e4e6ea;
  --accent: #9f1d32;
  --accent-dark: #751426;
  --navy: #202328;
}

body[data-theme="dark"] {
  --bg: #191a1d;
  --panel: #24262b;
  --ink: #f5f5f6;
  --muted: #b3b6bd;
  --line: #353840;
  --accent: #c8223e;
  --accent-dark: #a71931;
  --navy: #0c0c0e;
  --shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

.app-shell {
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: 100vh;
}

.sidebar {
  background: var(--navy);
  color: white;
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.brand-box {
  display: grid;
  gap: 12px;
}

.logo-frame {
  width: 170px;
  min-height: 126px;
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 8px;
  background: white;
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: 12px;
}

.logo-frame img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.logo-frame.has-logo {
  background: white;
}

.logo-frame.has-logo img {
  display: block;
}

.logo-frame.has-logo span {
  display: none;
}

.logo-button {
  width: fit-content;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.1);
  color: white;
  min-height: 38px;
  padding: 0 12px;
  font-weight: 800;
}

.logo-button:hover {
  background: rgba(255, 255, 255, 0.17);
}

.direction-link {
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 8px;
  color: white;
  display: inline-flex;
  justify-content: center;
  min-height: 42px;
  align-items: center;
  padding: 0 12px;
  text-decoration: none;
  font-weight: 900;
}

body[data-mode="advisor"] .admin-only {
  display: none;
}

body[data-mode="advisor"] .admin-settings {
  display: none;
}

.eyebrow {
  color: var(--gold);
  font-size: 0.76rem;
  font-weight: 800;
  letter-spacing: 0;
  margin: 0 0 6px;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  font-size: clamp(1.85rem, 5vw, 2.5rem);
  line-height: 1.05;
  margin-bottom: 0;
}

h2 {
  font-size: 1.75rem;
  margin-bottom: 0;
}

h3 {
  font-size: 1rem;
  margin-bottom: 0;
}

nav {
  display: grid;
  gap: 8px;
}

.nav-item {
  border: 0;
  border-radius: 8px;
  background: transparent;
  color: #dce2ee;
  padding: 12px 14px;
  text-align: left;
}

.nav-item:hover,
.nav-item.active {
  background: rgba(189, 23, 49, 0.24);
  color: white;
}

.workspace {
  padding: 30px;
  display: grid;
  gap: 22px;
  align-content: start;
}

.topbar,
.toolbar,
.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.topbar-actions {
  display: flex;
  align-items: end;
  gap: 12px;
}

.active-advisor {
  color: var(--muted);
  display: grid;
  gap: 6px;
  font-size: 0.88rem;
  font-weight: 800;
  min-width: 190px;
}

.primary-button,
.secondary-button,
.ghost-button {
  border: 0;
  border-radius: 8px;
  min-height: 42px;
  padding: 0 16px;
  font-weight: 800;
}

.primary-button {
  background: var(--accent);
  color: white;
}

.primary-button:hover {
  background: var(--accent-dark);
}

.secondary-button {
  background: #f4e8dc;
  color: var(--ink);
}

.ghost-button {
  background: transparent;
  color: var(--danger);
}

.metrics {
  display: grid;
  grid-template-columns: repeat(5, minmax(140px, 1fr));
  gap: 14px;
}

.metrics article,
.toolbar,
.advisor-panel,
.activity-panel,
.detail-panel,
.client-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.metrics article {
  padding: 18px;
}

.metric-alert span {
  color: var(--danger);
}

.metrics span {
  display: block;
  font-size: 1.65rem;
  font-weight: 900;
  margin-bottom: 4px;
}

.metrics p,
.client-card p,
.detail-panel p,
.section-heading span {
  color: var(--muted);
}

.toolbar {
  padding: 14px;
}

.toolbar label,
form label {
  color: var(--muted);
  display: grid;
  gap: 6px;
  font-size: 0.88rem;
  font-weight: 800;
}

.search-box {
  flex: 1;
}

.advisor-panel,
.activity-panel {
  padding: 18px;
}

.advisor-table {
  display: grid;
  gap: 8px;
  margin-top: 14px;
}

.advisor-row {
  display: grid;
  grid-template-columns: minmax(140px, 1.3fr) repeat(6, minmax(72px, 1fr));
  gap: 12px;
  align-items: center;
  border-top: 1px solid var(--line);
  padding: 11px 0 2px;
}

.login-screen {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 24px;
  background: #101012;
}

.login-card {
  width: min(430px, 100%);
  background: white;
  border-radius: 10px;
  box-shadow: 0 30px 90px rgba(0, 0, 0, 0.35);
  padding: 28px;
}

.login-card img {
  width: 150px;
  display: block;
  margin-bottom: 22px;
}

.login-card h1 {
  color: var(--ink);
  font-size: 2rem;
  margin-bottom: 18px;
}

.login-error {
  color: var(--danger);
  font-weight: 800;
  margin-bottom: 0;
}

.secondary-link {
  color: var(--muted);
  display: inline-flex;
  font-weight: 800;
  justify-content: center;
  text-decoration: none;
}

.locked {
  display: none;
}

.advisor-head {
  border-top: 0;
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
}

.activity-list {
  display: grid;
  gap: 10px;
  margin-top: 14px;
}

.activity-item {
  display: flex;
  gap: 10px;
  align-items: center;
  color: var(--muted);
}

.activity-item span {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--accent);
  flex: 0 0 auto;
}

.activity-item p {
  margin-bottom: 0;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: white;
  color: var(--ink);
  padding: 11px 12px;
  outline: none;
}

input:focus,
select:focus,
textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(189, 23, 49, 0.14);
}

.content-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 380px;
  gap: 18px;
  align-items: start;
}

.client-list {
  display: grid;
  gap: 12px;
  margin-top: 12px;
}

.client-card {
  width: 100%;
  padding: 16px;
  display: grid;
  gap: 12px;
  border-left-width: 5px;
}

.card-select {
  width: 100%;
  border: 0;
  background: transparent;
  color: inherit;
  display: grid;
  gap: 12px;
  padding: 0;
  text-align: left;
}

.client-card:hover,
.client-card.selected {
  border-color: var(--accent);
}

.client-card.tone-green {
  border-left-color: var(--green);
}

.client-card.tone-yellow {
  border-left-color: #e0aa00;
}

.client-card.tone-red {
  border-left-color: var(--danger);
}

.client-card.tone-blue {
  border-left-color: var(--blue);
}

.card-head,
.card-meta,
.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 14px;
  align-items: center;
}

.client-card strong {
  display: block;
  font-size: 1rem;
}

.client-card p {
  margin-bottom: 0;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.mini-chip {
  border-radius: 999px;
  background: #f0f0f2;
  color: #3d3f45;
  padding: 5px 9px;
  font-size: 0.74rem;
  font-weight: 900;
}

.mini-chip.priority-Alta {
  background: var(--green-soft);
  color: var(--green);
}

.mini-chip.priority-Media {
  background: var(--yellow-soft);
  color: var(--yellow);
}

.mini-chip.priority-Baja {
  background: #f2f2f3;
  color: #565960;
}

.alert-chip,
.detail-alert {
  background: #faeeee;
  color: var(--danger);
}

.badge {
  border-radius: 999px;
  background: var(--soft-red);
  color: var(--accent-dark);
  padding: 6px 10px;
  font-size: 0.78rem;
  font-weight: 900;
  white-space: nowrap;
}

.badge.stage-green {
  background: #e8f8f2;
  color: #15735f;
}

.badge.stage-red {
  background: #faeeee;
  color: var(--danger);
}

.badge.stage-yellow {
  background: #fff4d7;
  color: #8a5c0a;
}

.badge.stage-blue {
  background: var(--blue-soft);
  color: var(--blue);
}

.detail-panel {
  padding: 20px;
  position: sticky;
  top: 24px;
}

.detail-panel h3 {
  font-size: 1.35rem;
  margin-bottom: 4px;
}

.detail-grid {
  display: grid;
  gap: 9px;
  margin: 16px 0;
}

.detail-alert {
  display: inline-flex;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 900;
  margin-left: 8px;
  padding: 6px 10px;
}

.detail-row span {
  text-align: right;
}

.detail-actions {
  display: flex;
  gap: 10px;
  margin-top: 18px;
}

.quick-row {
  display: flex;
  gap: 10px;
  align-items: center;
  border-top: 1px solid var(--line);
  padding-top: 12px;
}

.quick-stage {
  min-width: 0;
  flex: 1;
}

.quick-whatsapp {
  border-radius: 8px;
  background: #111113;
  color: white;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 12px;
  text-decoration: none;
  font-weight: 900;
}

.link-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
}

.empty-state {
  margin-bottom: 0;
  line-height: 1.5;
}

dialog {
  width: min(760px, calc(100vw - 28px));
  border: 0;
  border-radius: 10px;
  padding: 0;
  box-shadow: 0 30px 90px rgba(0, 0, 0, 0.22);
}

#settingsDialog {
  width: min(920px, calc(100vw - 28px));
}

.settings-form {
  gap: 20px;
}

.settings-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.settings-grid section {
  border: 1px solid var(--line);
  border-radius: 8px;
  display: grid;
  gap: 12px;
  padding: 16px;
}

.settings-grid h3 {
  font-size: 1rem;
  margin-bottom: 4px;
}

.advisor-settings-list {
  display: grid;
  gap: 10px;
  max-height: 220px;
  overflow: auto;
}

.advisor-setting-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  gap: 8px;
  align-items: end;
}

dialog::backdrop {
  background: rgba(10, 25, 27, 0.45);
}

form {
  display: grid;
  gap: 18px;
  padding: 22px;
}

.dialog-head,
.dialog-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.icon-button {
  width: 36px;
  height: 36px;
  border: 0;
  border-radius: 50%;
  background: #eef3f3;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.dialog-actions > div {
  display: flex;
  gap: 10px;
}

@media (max-width: 980px) {
  .app-shell,
  .content-grid {
    grid-template-columns: 1fr;
  }

  .sidebar {
    min-height: auto;
  }

  nav {
    grid-template-columns: repeat(auto-fit, minmax(135px, 1fr));
  }

  .detail-panel {
    position: static;
  }

  .metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .advisor-row {
    grid-template-columns: 1.5fr repeat(6, minmax(48px, 1fr));
    font-size: 0.88rem;
  }
}

@media (max-width: 620px) {
  body {
    font-size: 15px;
  }

  .login-screen {
    align-items: start;
    padding: 18px;
  }

  .login-card {
    margin-top: 16px;
    padding: 22px;
  }

  .login-card img {
    width: 128px;
  }

  .workspace,
  .sidebar {
    padding: 18px;
  }

  .sidebar {
    gap: 18px;
  }

  .logo-frame {
    width: 138px;
    min-height: 102px;
  }

  h1 {
    font-size: 1.75rem;
  }

  h2 {
    font-size: 1.35rem;
  }

  .topbar,
  .toolbar,
  .card-meta,
  .quick-row,
  .dialog-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .metrics,
  .form-grid,
  .settings-grid {
    grid-template-columns: 1fr;
  }

  .metrics article {
    padding: 14px;
  }

  .content-grid {
    gap: 14px;
  }

  .client-card {
    padding: 14px;
  }

  .card-head,
  .detail-row {
    align-items: flex-start;
    flex-direction: column;
    gap: 6px;
  }

  .detail-row span {
    text-align: left;
  }

  dialog {
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    border-radius: 0;
  }

  form {
    padding: 18px;
  }

  .advisor-setting-row {
    grid-template-columns: 1fr;
  }

  .advisor-table {
    overflow-x: auto;
  }

  .advisor-row {
    min-width: 720px;
  }
}
